# OSINT Tool - Environment Configuration
# Copy file này thành .env và điền API keys của bạn
# Tất cả API keys đều tùy chọn — tool vẫn hoạt động không có keys, nhưng một số tính năng sẽ bị giới hạn.

# ─── Breach & Email ───────────────────────────────────────────────────────────

# HaveIBeenPwned API Key (Bắt buộc để kiểm tra email breaches)
# Đăng ký tại: https://haveibeenpwned.com/API/Key (~$3.50/tháng)
HIBP_API_KEY=

# Hunter.io API Key (Tìm email trên domain)
# Đăng ký tại: https://hunter.io (Gói miễn phí: 25 req/tháng)
HUNTER_KEY=

# EmailRep.io API Key (Điểm uy tín email)
# Đăng ký tại: https://emailrep.io (Gói miễn phí có giới hạn)
EMAILREP_KEY=

# ─── IP & Domain Intelligence ─────────────────────────────────────────────────

# Shodan API Key (Quét port mở, CVE, banner services)
# Đăng ký tại: https://shodan.io (Gói miễn phí: 100 req/tháng)
SHODAN_KEY=

# VirusTotal API Key (Phân tích malware, threat intel)
# Đăng ký tại: https://virustotal.com (Gói miễn phí: 1000 req/ngày)
VIRUSTOTAL_KEY=

# AbuseIPDB API Key (Kiểm tra IP có bị báo cáo lạm dụng)
# Đăng ký tại: https://abuseipdb.com (Gói miễn phí: 1000 req/ngày)
ABUSEIPDB_KEY=

# ─── Phone ───────────────────────────────────────────────────────────────────

# NumVerify API Key (Xác thực số điện thoại live)
# Đăng ký tại: https://numverify.com (Gói miễn phí: 100 req/tháng)
NUMVERIFY_KEY=

# ─── Social Media (RapidAPI) ─────────────────────────────────────────────────
# Đăng ký một lần tại: https://rapidapi.com để lấy tất cả các key bên dưới

# TikTok Scraper API Key
TIKTOK_API_KEY=

# Instagram Scraper API Key
INSTAGRAM_KEY=

# Facebook Scraper API Key
FACEBOOK_SCRAPER_KEY=

# TokAPI (TikTok alternative) Key
TOKAPI_KEY=

# ─── Data Breach ─────────────────────────────────────────────────────────────

# BreachDirectory API Key (RapidAPI) — kiểm tra breach database
# Đăng ký tại: https://rapidapi.com/rohan-patra/api/breachdirectory (Gói miễn phí: 100 req/tháng)
BREACHDIRECTORY_KEY=

# ─── Social / Content ────────────────────────────────────────────────────────

# Twitter Bearer Token (Tra cứu Twitter/X profile)
# Đăng ký tại: https://developer.twitter.com
TWITTER_BEARER_TOKEN=

# YouTube Data API v2 Key (RapidAPI) — OSINT kênh YouTube
YOUTUBE_V2_KEY=

# Website Contacts Scraper (RapidAPI) — email, phone từ website
WEBSITE_CONTACTS_KEY=

# ─── Output ───────────────────────────────────────────────────────────────────

# Thư mục lưu báo cáo (mặc định: ./reports)
OSINT_OUTPUT_DIR=./reports
